# Copy to .env and fill in values.

# Telegram (required to run the bot)
TELEGRAM_BOT_TOKEN=

# Logging: INFO (default), DEBUG for chunk text previews + per-token stream deltas
# LOG_LEVEL=INFO

# Seconds between Telegram "typing" actions while the model streams
# STREAM_TYPING_INTERVAL_SEC=4.5

# Health-domain gate (embedding similarity to anchors). Disable to always run RAG.
# DOMAIN_GATE_ENABLED=true
# DOMAIN_GATE_MIN_SIMILARITY=0.32

# Query typo correction: digit+letter tokens mapped to nearest health term (same embedder)
# QUERY_TYPO_MIN_SIMILARITY=0.50

# Ollama
OLLAMA_HOST=http://127.0.0.1:11434
OLLAMA_MODEL=mistral

# Artifact store (SQLite + FAISS + config.json)
RAG_STORE_PATH=var

# Retrieval: dense (FAISS) default; hybrid (dense + BM25) for larger mixed corpora
# RETRIEVAL_BACKEND=dense
# Chunks after ranking (default 3)
# RETRIEVAL_FINAL_K=3

# Optional: must match persisted store or run ingest --rebuild
# EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2
# CHUNK_SIZE_TOKENS=350
# CHUNK_OVERLAP_TOKENS=20

# Document root (ingest CLI defaults; can override with CLI flags)
DOCS_DIR=Data/docs

# Gradio debug UI (health-rag-ui)
# GRADIO_SERVER_NAME=127.0.0.1
# GRADIO_SERVER_PORT=7860
